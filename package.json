{
  "name": "@ace-grid/mcp",
  "version": "1.0.8",
  "description": "Model Context Protocol server for Ace Grid docs, API metadata, config validation, migration help, and framework examples.",
  "type": "module",
  "bin": {
    "ace-grid-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node scripts/clean-dist.mjs",
    "demo": "tsx src/demoServer.ts",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "sync:docs": "tsx scripts/export-docs-index.ts",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Vitashev/ace-grid-mcp.git"
  },
  "keywords": [
    "ace-grid",
    "mcp",
    "model-context-protocol",
    "data-grid",
    "react",
    "ai"
  ],
  "author": "Ace Grid",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/Vitashev/ace-grid-mcp/issues"
  },
  "homepage": "https://ace-grid.com",
  "publishConfig": {
    "access": "public"
  }
}
